{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "stock_status": {
      "type": "string",
      "enum": [
        "in_stock",
        "low_stock",
        "out_of_stock"
      ],
      "default": "in_stock"
    },
    "description": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "price"
  ]
}