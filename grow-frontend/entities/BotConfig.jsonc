{
  "name": "BotConfig",
  "type": "object",
  "properties": {
    "provider": {
      "type": "string",
      "default": "Groq Cloud"
    },
    "model": {
      "type": "string",
      "default": "llama-3.1-8b-instant"
    },
    "api_key": {
      "type": "string"
    },
    "system_prompt": {
      "type": "string"
    }
  },
  "required": [
    "provider",
    "model"
  ]
}