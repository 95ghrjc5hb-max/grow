{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_id": {
      "type": "string"
    },
    "customer_name": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "product_name": {
      "type": "string"
    },
    "total_price": {
      "type": "number"
    },
    "order_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "shipped",
        "cancelled"
      ],
      "default": "pending"
    },
    "channel": {
      "type": "string",
      "enum": [
        "messenger",
        "instagram",
        "whatsapp"
      ]
    }
  },
  "required": [
    "order_id",
    "customer_name",
    "product_name",
    "total_price"
  ]
}